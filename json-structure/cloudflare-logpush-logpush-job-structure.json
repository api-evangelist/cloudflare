{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "LogpushJob",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer"
    },
    "name": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    },
    "dataset": {
      "type": "string"
    },
    "destination_conf": {
      "type": "string"
    },
    "logpull_options": {
      "type": "string"
    },
    "frequency": {
      "type": "string"
    },
    "last_complete": {
      "type": "string"
    },
    "last_error": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    }
  }
}