{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "AiRunRequest",
  "type": "object",
  "properties": {
    "prompt": {
      "type": "string"
    },
    "messages": {
      "type": "array"
    },
    "image": {
      "type": "array"
    },
    "text": {
      "type": "string"
    },
    "source_lang": {
      "type": "string"
    },
    "target_lang": {
      "type": "string"
    },
    "max_tokens": {
      "type": "integer"
    },
    "temperature": {
      "type": "number"
    },
    "stream": {
      "type": "boolean"
    }
  }
}