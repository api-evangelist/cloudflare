{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Video",
  "type": "object",
  "properties": {
    "uid": {
      "type": "string"
    },
    "thumbnail": {
      "type": "string"
    },
    "playback": {
      "type": "object"
    },
    "status": {
      "type": "object"
    },
    "meta": {
      "type": "object"
    },
    "created": {
      "type": "string"
    },
    "modified": {
      "type": "string"
    },
    "duration": {
      "type": "number"
    },
    "size": {
      "type": "integer"
    },
    "requireSignedURLs": {
      "type": "boolean"
    },
    "allowedOrigins": {
      "type": "array"
    }
  }
}